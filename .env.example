# The device specified within the package
PKG_NAME=device

# URL to download the PDF from (best-effort; if download fails, PDF_LOCAL_PATH is used)
PDF_URL=https://mev-energy.de/wp-content/uploads/250423_using-mobus-tcp.pdf

# Local path to the PDF file (used if URL download fails or is not set)
PDF_LOCAL_PATH=250423_using-mobus-tcp.pdf

# Override output path (optional — auto-increments to vN+1.json when not set)
# OUTPUT_PATH=src/device/schemas/v3.json

# Device metadata
DEVICE_NAME="DEVICE"
VERSION=1.0
